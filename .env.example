# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (existing project)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (email delivery)
RESEND_API_KEY=re_...

# Tavily (optional — web search for Research Agent)
# Free tier: 1000 searches/month — https://tavily.com
TAVILY_API_KEY=tvly-...

# PDFShift (Phase 2 — PDF generation)
PDFSHIFT_API_KEY=sk_...

# Resend from email (Phase 2 — use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=onboarding@resend.dev

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Payment network (USDC on Base) ────────────────────────────────────────────
# Single switch for the whole app. "true" => Base mainnet; anything else (or
# unset) => Base Sepolia testnet. The viem chain, USDC contract, x402 network
# slug, RPC endpoint, and UI copy all flip together off this one flag
# (see apps/web/lib/network.ts). Default: testnet.
NEXT_PUBLIC_USE_MAINNET=false

# Recipient / payout addresses. All three default to the Agent Studio wallet
# (0x8250231307A1Aa9cfd47e7be9258D5eF49fc83FF); set them only to override.
#   NEXT_PUBLIC_PAYMENT_ADDRESS — client-side transfer recipient (lib/payment.ts)
#   PAYMENT_ADDRESS             — server-side verification target (lib/payment-verify.ts)
#   X402_PAYMENT_ADDRESS        — x402 proxy recipient (proxy.ts)
NEXT_PUBLIC_PAYMENT_ADDRESS=0x8250231307A1Aa9cfd47e7be9258D5eF49fc83FF
PAYMENT_ADDRESS=0x8250231307A1Aa9cfd47e7be9258D5eF49fc83FF
X402_PAYMENT_ADDRESS=0x8250231307A1Aa9cfd47e7be9258D5eF49fc83FF

# RPC endpoint for onchain payment verification. Defaults to the public Base RPC
# for the active network; override with a CDP / Alchemy / Infura URL for
# reliability and rate-limit headroom in production.
BASE_RPC_URL=https://sepolia.base.org

# Dynamic Context Layer (DCL)
# When "false", the pipeline reverts to its pre-DCL behaviour: no Context Extractor,
# no context packages injected into agent prompts, and the Implementation Architect
# reviewer is skipped. Any other value (or unset) enables DCL. Default: enabled.
NEXT_PUBLIC_ENABLE_DCL=true

# Operator view toggle. "0" (default/unset) => public client-facing UI: the
# token/cost chip, Dynamic Context panel and per-agent diagnostics are hidden.
# "1" => operator sees all internal instrumentation. UI visibility only — data is
# still computed and persisted the same. Production Netlify: 0; operator: 1 locally.
NEXT_PUBLIC_OPERATOR_MODE=0

# ── Final QA Gate ─────────────────────────────────────────────────────────────
# Model the Final QA Gate judges with. Default is Opus 4.8; set a Sonnet string to
# cut cost (e.g. claude-sonnet-4-6). Read server-side by lib/agents/finalQa.ts.
DCL_GATE_MODEL=claude-opus-4-8
# FAIL -> revise loop cap before the gate force-passes (delivers with a warning so a
# paying client is never blocked). Default 2. NEXT_PUBLIC_ variant is read by the
# browser orchestrator; keep them in sync if you set both.
DCL_GATE_MAX_CYCLES=2
NEXT_PUBLIC_DCL_GATE_MAX_CYCLES=2

# ── Mock / Fixture Mode (zero API spend) ──────────────────────────────────────
# "1" => every agent returns a deterministic fixture instead of calling Anthropic.
# Server workers read AS_MOCK; the browser orchestrator reads NEXT_PUBLIC_AS_MOCK and
# additionally skips the job plumbing (so no Supabase is needed either). Default "0".
AS_MOCK=0
NEXT_PUBLIC_AS_MOCK=0
# Under mock mode, force the gate verdict so the loop guard / force-pass are testable:
# "pass" | "pass_with_minor_fixes" | "fail". Unset => "pass". NEXT_PUBLIC_ variant is
# used by the browser orchestrator's mock bypass.
# DCL_GATE_MOCK_VERDICT=fail
# NEXT_PUBLIC_DCL_GATE_MOCK_VERDICT=fail

# ── Context Store ─────────────────────────────────────────────────────────────
# "supabase" (default) persists to the as_dcl_* tables via REST; "memory" uses an
# in-process InMemoryContextStore (no Supabase creds needed — used by mock mode).
DCL_STORE=supabase
